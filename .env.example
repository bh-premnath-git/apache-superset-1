# ── Superset ──────────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=change_me_to_a_random_32_char_string
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_APP_NAME=BigHammer
SUPERSET_APP_ICON=/static/assets/images/logo.svg
SUPERSET_APP_FAVICON=/static/assets/images/logo.svg
SUPERSET_URL=http://superset:8088

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=bighammer-admin
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:8088/oauth-authorized/keycloak
KEYCLOAK_API_BASE_URL=http://keycloak:8080/realms/master/protocol/openid-connect
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASS=keycloak
KEYCLOAK_BOOTSTRAP_USERNAME=superset-user
KEYCLOAK_BOOTSTRAP_PASSWORD=superset123
KEYCLOAK_BOOTSTRAP_EMAIL=superset@example.com
KEYCLOAK_BOOTSTRAP_ROLE=superset_gamma
KEYCLOAK_ROLE_CLAIM=role_keys

# ── Superset metadata DB (Postgres) ──────────────────────────────────────────
METADATA_DB_USER=superset
METADATA_DB_PASS=superset
METADATA_DB_NAME=superset
METADATA_DB_HOST=metadata-db
METADATA_DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Sample Analytics Postgres DB ──────────────────────────────────────────────
ANALYTICS_DB_USER=sample_user
ANALYTICS_DB_PASS=sample_pass
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_HOST=analytics-db
ANALYTICS_DB_PORT=5432

# SQLAlchemy URI referenced by declarative asset specs (see
# assets/databases/analytics.yaml -> spec.sqlalchemyUriFromEnv).
ANALYTICS_DB_URI=postgresql+psycopg2://sample_user:sample_pass@analytics-db:5432/analytics

# ── Optional branding overrides ───────────────────────────────────────────────
MAPBOX_API_KEY=

# ── Shared PostgreSQL image tag ──────────────────────────────────────────────
POSTGRES_IMAGE=postgres:18-alpine

# ── Superset image ───────────────────────────────────────────────────────────
# Pinned to the 6.1 release-candidate line because it ships the built-in
# ``superset mcp run`` CLI.  Any Docker Hub tag that has the MCP command
# will work — e.g. 6.1.0rc2, 6.1.0rc2-py311, 6.1.0rc2-py312.
SUPERSET_BASE_IMAGE=apache/superset:6.1.0rc2

# ── MCP (Model Context Protocol) service ─────────────────────────────────────
# MCP is enabled by default and starts with ``docker compose up``.
# Port exposed on the host by the MCP container:
MCP_PORT=5008
#
# ── Dev auth (simple impersonation — NOT for production) ─────────────────────
# The MCP server uses this Superset user for every request.  The user must
# exist in the Superset database (e.g. the admin created by superset-init).
MCP_DEV_USERNAME=admin
#
# ── Production auth (JWT validation, e.g. Keycloak) ──────────────────────────
# Flip MCP_AUTH_ENABLED to True and fill in the issuer/audience/keys.
MCP_AUTH_ENABLED=False
MCP_JWT_ALGORITHM=RS256
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=
MCP_JWKS_URI=
MCP_JWT_SECRET=
MCP_JWT_PUBLIC_KEY=

# ── Dynamic Plugins (optional) ───────────────────────────────────────────────
# FEATURE_FLAGS["DYNAMIC_PLUGINS"] = True is required in superset_config.py.
# Each plugin declares its own env-var keys in assets/plugins/<name>.yaml.
# Resolution order per plugin (see _resolve_bundle_url in seed_dashboard.py):
#   1. *_BUNDLE_URL  — ready-to-use URL (CDN, static serve, etc.)
#   2. *_BUNDLE_PATH — local build path (reconciler derives URL via staticMountPath)
#   3. bundleUrl     — literal fallback in YAML (not recommended)
#
# ⚠️  Known upstream issue: API may 404 even with flag enabled in 6.0-6.1
#    https://github.com/apache/superset/issues/35870
#
# STATE_DISTRICT_PIES_PLUGIN_BUNDLE_URL=
# STATE_DISTRICT_PIES_PLUGIN_BUNDLE_PATH=/plugin-dist/main.xxxxx.js

# ── Extensions (optional) ────────────────────────────────────────────────────
# To register a Superset extension (.supx), enable the feature flag in
# superset_config.py (FEATURE_FLAGS["ENABLE_EXTENSIONS"] = True) and set the
# path or URL below.  Build .supx with: superset-extensions bundle
#
# ⚠️  Lifecycle: IN DEVELOPMENT — API may 404 even with flag enabled in 6.0-6.1
#    https://github.com/apache/superset/discussions/38607
#    Extensions framework is not yet production-ready. Consider dynamic
#    plugins or embedded dashboards for production use today.
#
# QUERY_OPTIMIZER_SUPX_PATH=/app/extensions/my-org.query-optimizer-1.2.0.supx
# QUERY_OPTIMIZER_SUPX_URL=https://registry.example.com/extensions/my-org.query-optimizer-1.2.0.supx
# DASHBOARD_CHATBOT_SUPX_PATH=/app/extensions/my-org.dashboard-chatbot-0.1.0.supx
# DASHBOARD_CHATBOT_SUPX_URL=https://registry.example.com/extensions/my-org.dashboard-chatbot-0.1.0.supx
