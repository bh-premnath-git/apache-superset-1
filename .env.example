# ── Superset ──────────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=change_me_to_a_random_32_char_string
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_APP_NAME=BigHammer
SUPERSET_APP_ICON=/static/assets/images/logo.svg
SUPERSET_APP_FAVICON=/static/assets/images/logo.svg
SUPERSET_URL=http://superset:8088

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=bighammer-admin
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:8088/oauth-authorized/keycloak
KEYCLOAK_API_BASE_URL=http://keycloak:8080/realms/master/protocol/openid-connect
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASS=keycloak
KEYCLOAK_BOOTSTRAP_USERNAME=superset-user
KEYCLOAK_BOOTSTRAP_PASSWORD=superset123
KEYCLOAK_BOOTSTRAP_EMAIL=superset@example.com
KEYCLOAK_BOOTSTRAP_ROLE=superset_gamma
KEYCLOAK_ROLE_CLAIM=role_keys

# ── Superset metadata DB (Postgres) ──────────────────────────────────────────
METADATA_DB_USER=superset
METADATA_DB_PASS=superset
METADATA_DB_NAME=superset
METADATA_DB_HOST=metadata-db
METADATA_DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Sample Analytics Postgres DB ──────────────────────────────────────────────
ANALYTICS_DB_USER=sample_user
ANALYTICS_DB_PASS=sample_pass
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_HOST=analytics-db
ANALYTICS_DB_PORT=5432

# SQLAlchemy URI referenced by declarative asset specs (see
# assets/databases/analytics.yaml -> spec.sqlalchemyUriFromEnv).
ANALYTICS_DB_URI=postgresql+psycopg2://sample_user:sample_pass@analytics-db:5432/analytics

# ── Optional branding overrides ───────────────────────────────────────────────
MAPBOX_API_KEY=

# ── Shared PostgreSQL image tag ──────────────────────────────────────────────
POSTGRES_IMAGE=postgres:18-alpine
